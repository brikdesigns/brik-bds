---
/**
 * hero_interior_minimal — Phase D Astro renderer for the `bds-hero` family,
 * `--interior-minimal` layout (brik-bds#583). Twin of the React
 * `<Hero layout="interior-minimal">` adapter. Text-only interior page hero:
 * eyebrow + headline + optional lead, no image. Owns the page's `h1`.
 *
 * Contract: BlueprintProps (section + clientFacts + theme).
 *   - section.heading    — h1 (REQUIRED by content gen)
 *   - section.subheading — eyebrow above h1 (optional)
 *   - section.body       — lead paragraph (optional)
 *   - section.cta        — primary CTA (optional; rare on interior heroes)
 *
 * required_facts: []. Renders entirely from section content.
 *
 * CSS custom properties (Tier-4 hooks — shared with the family):
 *   --bds-hero-bg              (default: var(--page-primary))
 *   --bds-hero-headline-color  (default: var(--text-primary))
 *   --bds-hero-eyebrow-color   (default: var(--text-brand-primary))
 *   --bds-hero-lead-color      (default: var(--text-secondary))
 *
 * a11y: h1 + aria-labelledby. Eyebrow is prose, not a heading. Static layout.
 */
import type { BlueprintProps } from './types';

interface Props extends BlueprintProps {}

const { section } = Astro.props;

const titleId = `${section.sectionKey}-title`;
const eyebrow = section.subheading;
const headline = section.heading ?? '';
const lead = section.body;
const cta = section.cta;
---

<section
  class="bds-hero bds-hero--interior-minimal"
  aria-labelledby={titleId}
  data-blueprint-key="hero_interior_minimal"
>
  <div class="bds-hero__container">
    <div class="bds-hero__content">
      {eyebrow && <p class="bds-hero__subtitle">{eyebrow}</p>}
      <h1 id={titleId} class="bds-hero__title">{headline}</h1>
      {lead && <p class="bds-hero__lead">{lead}</p>}
      {cta && 'url' in cta && (
        <a href={cta.url} class="bds-button bds-button--primary bds-button--md"><span class="bds-button__content">{cta.label}</span></a>
      )}
    </div>
  </div>
</section>

<style>
  .bds-hero {
    background: var(--bds-hero-bg, var(--page-primary));
    padding-block: clamp(var(--space-2xl), 6vw, var(--space-4xl));
  }

  .bds-hero__container {
    max-width: 72ch;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .bds-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .bds-hero__subtitle {
    margin: 0;
    font-family: var(--font-family-label);
    font-size: var(--label-lg);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bds-hero-eyebrow-color, var(--text-brand-primary));
  }

  .bds-hero__title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: clamp(var(--heading-xl), 4vw, var(--display-sm));
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--bds-hero-headline-color, var(--text-primary));
  }

  .bds-hero__lead {
    margin: var(--space-sm) 0 0;
    font-family: var(--font-family-body);
    font-size: var(--heading-sm);
    line-height: var(--line-height-relaxed);
    color: var(--bds-hero-lead-color, var(--text-secondary));
  }
</style>
