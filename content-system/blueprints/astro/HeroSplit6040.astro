---
/**
 * hero_split_60_40 — Phase D Astro renderer for the `bds-hero` family,
 * `--split` layout (brik-bds#583). Twin of the React `<Hero layout="split">`
 * adapter. 60/40 split hero — content left, photography right, gold accent
 * line under the headline. Owns the page's `h1`.
 *
 * Contract: BlueprintProps.
 *   - section.heading    — h1 (REQUIRED)
 *   - section.subheading — eyebrow above h1 (optional)
 *   - section.body       — lead paragraph (optional)
 *   - section.cta        — primary CTA (optional)
 *   - clientFacts.heroImageUrl — right column; emits a
 *     `data-content-needed="hero_image_url"` stub when missing (CI greppable).
 *
 * CSS custom properties (Tier-4 hooks — shared with the family):
 *   --bds-hero-bg              (default: var(--page-primary))
 *   --bds-hero-headline-color  (default: var(--text-primary))
 *   --bds-hero-eyebrow-color   (default: var(--text-brand-primary))
 *   --bds-hero-lead-color      (default: var(--text-secondary))
 *   --bds-hero-accent-line     (default: var(--border-brand-primary))
 *   --bds-hero-image-radius    (default: var(--border-radius-lg))
 *
 * a11y: h1 + aria-labelledby. Eyebrow is prose, not a heading. Image alt is
 * the decorative-default empty string (the h1 conveys meaning). Static layout.
 */
import type { BlueprintProps } from './types';

interface Props extends BlueprintProps {}

const { section, clientFacts } = Astro.props;

const titleId = `${section.sectionKey}-title`;
const eyebrow = section.subheading;
const headline = section.heading ?? '';
const lead = section.body;
const cta = section.cta;
const heroImage = clientFacts.heroImageUrl;
const imageAlt = '';
---

<section
  class="bds-hero bds-hero--split"
  aria-labelledby={titleId}
  data-blueprint-key="hero_split_60_40"
>
  <div class="bds-hero__container">
    <div class="bds-hero__content">
      {eyebrow && <p class="bds-hero__subtitle">{eyebrow}</p>}
      <h1 id={titleId} class="bds-hero__title">{headline}</h1>
      {lead && <p class="bds-hero__lead">{lead}</p>}
      {cta && 'url' in cta && (
        <a href={cta.url} class="bds-button bds-button--primary bds-button--md">
          <span class="bds-button__content">{cta.label}</span>
        </a>
      )}
    </div>

    {heroImage ? (
      <div class="bds-hero__media">
        <img
          src={heroImage}
          alt={imageAlt}
          width="960"
          height="1200"
          loading="eager"
          decoding="async"
          class="bds-hero__image"
        />
      </div>
    ) : (
      <div
        class="bds-hero__missing"
        data-content-needed="hero_image_url"
        role="presentation"
      >
        <p class="bds-hero__missing-label">
          Hero image missing for this client.
        </p>
      </div>
    )}
  </div>
</section>

<style>
  .bds-hero {
    background: var(--bds-hero-bg, var(--page-primary));
    padding-block: clamp(var(--space-3xl), 8vw, var(--space-5xl));
  }

  .bds-hero__container {
    max-width: var(--size-container-xl, 1280px);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .bds-hero__container {
      grid-template-columns: 3fr 2fr;
      gap: var(--space-3xl);
    }
  }

  .bds-hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .bds-hero__subtitle {
    margin: 0;
    font-family: var(--font-family-label);
    font-size: var(--label-lg);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bds-hero-eyebrow-color, var(--text-brand-primary));
  }

  .bds-hero__title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: clamp(var(--heading-xxl), 5vw, var(--display-sm));
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--bds-hero-headline-color, var(--text-primary));
    position: relative;
  }

  @media (min-width: 768px) {
    .bds-hero__title::after {
      content: '';
      display: block;
      width: 3rem;
      height: 2px;
      margin-top: var(--space-lg);
      background: var(--bds-hero-accent-line, var(--border-brand-primary));
    }
  }

  .bds-hero__lead {
    margin: var(--space-md) 0 0;
    font-family: var(--font-family-body);
    font-size: var(--heading-sm);
    line-height: var(--line-height-relaxed);
    color: var(--bds-hero-lead-color, var(--text-secondary));
    max-width: 55ch;
  }

  .bds-hero__media {
    aspect-ratio: var(--aspect-4-5);
    overflow: hidden;
    border-radius: var(--bds-hero-image-radius, var(--border-radius-lg));
  }

  .bds-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bds-hero__missing {
    aspect-ratio: var(--aspect-4-5);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: var(--surface-secondary);
    border: 2px dashed var(--border-secondary);
    border-radius: var(--bds-hero-image-radius, var(--border-radius-lg));
  }

  .bds-hero__missing-label {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--body-xl);
    color: var(--text-secondary);
    text-align: center;
  }
</style>
