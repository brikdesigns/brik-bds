---
/**
 * ServicesDetailTwoColumn — Phase D adapter (deprecated direct path).
 *
 * After ADR-008 / brik-bds#580, the canonical primitive is `<Services>`
 * (`./Services.astro`) composed with consumer-supplied list markup.
 * This file remains as an adapter so the legacy
 * `services_detail_two_column` blueprint key continues to dispatch
 * through `BlueprintDispatcher` with the same section-data contract.
 *
 * The legacy `bp-services-two-col-*` classes are preserved INSIDE this
 * adapter's scoped style block — internal deprecated implementation
 * that goes away in Phase E.
 *
 * @deprecated Use `<Services>` directly with composed slot content.
 * @summary Legacy adapter — `<Services>` wrapping 2-col title/desc list.
 */
import type { BlueprintProps } from './types';
import Services from './Services.astro';

interface Props extends BlueprintProps {}

const { section } = Astro.props;
---

<Services
  sectionKey={section.sectionKey}
  title={section.heading ?? ''}
  subtitle={section.subheading ?? undefined}
  description={section.body ?? undefined}
>
  <ul class="bp-services-two-col__list" role="list">
    {section.items.map((item) => (
      <li class="bp-services-two-col__item">
        <h3 class="bp-services-two-col__item-title">{item.title}</h3>
        <p class="bp-services-two-col__item-desc">{item.description}</p>
      </li>
    ))}
  </ul>
</Services>

<style>
  /* Scoped to this deprecated adapter — NOT part of the bds-services
     canon vocabulary. Goes away with the adapter in Phase E. */

  .bp-services-two-col__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap-xl);
  }

  @media (min-width: 768px) {
    .bp-services-two-col__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--gap-xl) var(--gap-huge);
    }
  }

  .bp-services-two-col__item {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .bp-services-two-col__item-title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: var(--heading-md);
    font-weight: var(--font-weight-semibold);
    line-height: var(--font-line-height-tight);
    color: var(--text-primary);
  }

  .bp-services-two-col__item-desc {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--body-xl);
    line-height: var(--font-line-height-relaxed);
    color: var(--text-primary);
  }
</style>
