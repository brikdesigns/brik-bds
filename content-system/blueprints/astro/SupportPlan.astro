---
/**
 * SupportPlan — `bds-support-plan` section primitive. Astro twin of
 * `../react/SupportPlan.tsx` (Phase D, brik-bds#581). Section header
 * (subtitle + title + lead) above a plan-callout card, with an optional
 * `media` slot rendered beside the card.
 *
 * Per brik-bds#589 the default shape is the simple single-column callout
 * (eyebrow + heading + body + one CTA); fill the `media` slot only when a
 * decorative scene exists. The `support_plan_callout_split` blueprint key
 * dispatches through `SupportPlanCalloutSplit.astro`, which fills the
 * `media` slot with a `MarketingIllustration` scene.
 *
 * Slots used (all on docs/SLOT-ALLOWLIST.md):
 *   bds-support-plan, __container, __header, __subtitle, __title,
 *   __description, __columns, __illustration, __main, __cta
 *
 * a11y: section uses h2 + aria-labelledby; plan title is an h3 nested
 * under the section h2. CTA passes AA at the canonical `md` button size
 * (16px label) — DO NOT downgrade to `sm` on this surface.
 */
import type { BlueprintCta } from './types';

export interface Props {
  sectionKey: string;
  title: string;
  subtitle?: string;
  description?: string;
  planTitle: string;
  planDescription?: string;
  cta?: BlueprintCta;
}

const {
  sectionKey,
  title,
  subtitle,
  description,
  planTitle,
  planDescription,
  cta,
} = Astro.props;
const titleId = `${sectionKey}-title`;
const hasMedia = Astro.slots.has('media');
// Astro blueprints are static — only the link CTA form is renderable.
const ctaUrl = cta && 'url' in cta ? cta.url : undefined;
---

<section
  class="bds-support-plan"
  data-blueprint-key="support_plan_callout_split"
  data-has-media={hasMedia ? 'true' : 'false'}
  aria-labelledby={titleId}
>
  <div class="bds-support-plan__container">
    {(subtitle || title || description) && (
      <header class="bds-support-plan__header">
        {subtitle && <p class="bds-support-plan__subtitle">{subtitle}</p>}
        <h2 id={titleId} class="bds-support-plan__title">{title}</h2>
        {description && (
          <p class="bds-support-plan__description">{description}</p>
        )}
      </header>
    )}

    <div class="bds-support-plan__columns">
      {hasMedia && (
        <div class="bds-support-plan__illustration">
          <slot name="media" />
        </div>
      )}

      <article class="bds-support-plan__main">
        <h3 class="bds-support-plan__title">{planTitle}</h3>
        {planDescription && (
          <p class="bds-support-plan__description">{planDescription}</p>
        )}
        {cta && ctaUrl && (
          <a
            class="bds-button bds-button--primary bds-button--md bds-support-plan__cta"
            href={ctaUrl}
          >
            <span class="bds-button__content">{cta.label}</span>
          </a>
        )}
      </article>
    </div>
  </div>
</section>

<style>
  /* Mirrors ../react/SupportPlan.css — keep in sync until a unified CSS
     distribution lands across the React + Astro twins. */

  .bds-support-plan {
    background: var(--bds-support-plan-bg, var(--page-primary));
    padding-block: clamp(var(--padding-xl), 9vw, var(--padding-huge));
  }

  .bds-support-plan__container {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--padding-lg);
  }

  /* ── Section header ─────────────────────────────────────────── */

  .bds-support-plan__header {
    text-align: center;
    max-width: 72ch;
    margin-inline: auto;
    margin-bottom: var(--padding-xl);
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .bds-support-plan__subtitle {
    margin: 0;
    font-family: var(--font-family-label);
    font-size: var(--label-lg);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-brand-primary);
  }

  .bds-support-plan__header .bds-support-plan__title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: clamp(var(--heading-lg), 3.5vw, var(--heading-xl));
    font-weight: var(--font-weight-semibold);
    line-height: var(--font-line-height-tight);
    color: var(--text-primary);
  }

  .bds-support-plan__header .bds-support-plan__description {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--heading-sm);
    line-height: var(--font-line-height-relaxed);
    color: var(--text-primary);
  }

  /* ── Two-column split ───────────────────────────────────────── */

  .bds-support-plan__columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--bds-support-plan-gap, var(--gap-xl));
    align-items: center;
  }

  .bds-support-plan[data-has-media='false'] .bds-support-plan__columns {
    grid-template-columns: 1fr;
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 991.98px) {
    .bds-support-plan__columns {
      grid-template-columns: 1fr;
    }
  }

  .bds-support-plan__illustration {
    order: 1;
  }
  .bds-support-plan__main {
    order: 2;
  }

  /* ── Plan callout card ──────────────────────────────────────── */

  .bds-support-plan__main {
    background: var(--bds-support-plan-card-bg, var(--surface-secondary));
    border-radius: var(--bds-support-plan-card-radius, var(--border-radius-lg));
    padding: var(--bds-support-plan-card-pad, var(--padding-xl));
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    align-items: flex-start;
  }

  .bds-support-plan__main .bds-support-plan__title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: var(--heading-md);
    font-weight: var(--font-weight-semibold);
    line-height: var(--font-line-height-tight);
    color: var(--text-primary);
  }

  .bds-support-plan__main .bds-support-plan__description {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--body-xl);
    line-height: var(--font-line-height-relaxed);
    color: var(--text-primary);
  }

  .bds-support-plan__cta {
    margin-top: var(--gap-md);
  }
</style>
