---
/**
 * support_plan_callout_split — Phase D adapter (deprecated direct path).
 *
 * After brik-bds#581 the canonical primitive is `<SupportPlan>` (the
 * `bds-support-plan` section block). This file remains as the adapter
 * the `BlueprintDispatcher` dispatches to for the
 * `support_plan_callout_split` key: it maps `section.*` → `<SupportPlan>`
 * props.
 *
 * New consumers should compose `<SupportPlan>` directly. Retires in Phase E.
 *
 * Contract: BlueprintProps.
 *   - section.heading      — section heading (h2)
 *   - section.subheading   — optional eyebrow (uppercase)
 *   - section.body         — optional one-line lead under heading
 *   - section.items[0]     — { title: plan name, description: plan description }
 *   - section.cta          — { label, url } for the plan CTA
 */
import type { BlueprintProps } from './types';
import SupportPlan from './SupportPlan.astro';

interface Props extends BlueprintProps {}

const { section } = Astro.props;
const plan = section.items?.[0];
---

<SupportPlan
  sectionKey={section.sectionKey}
  title={section.heading ?? ''}
  subtitle={section.subheading ?? undefined}
  description={section.body ?? undefined}
  planTitle={plan?.title ?? ''}
  planDescription={plan?.description ?? undefined}
  cta={section.cta ?? undefined}
/>
