---
/**
 * cta_dark_centered — Phase D Astro renderer for the `bds-cta` family
 * (default single-column layout). Twin of the React `<Cta>` primitive
 * (brik-bds#582). The former `bp-cta-dark-centered` class baked theme
 * (`dark`) + alignment (`centered`) into the name — both banned by
 * ADR-008 §3; the block is now the structural `bds-cta`, and the inverse
 * surface is a themeable default, not part of the name. Heading + optional
 * body + single primary action, center-aligned. The workhorse closing CTA.
 *
 * Contract: BlueprintProps.
 *   - section.heading — CTA headline (h2)
 *   - section.body    — optional supporting paragraph
 *   - section.cta     — primary action (label + url) (REQUIRED)
 *
 * required_facts: []. Section-driven.
 *
 * CSS custom properties (Tier-4 hooks):
 *   --bds-cta-bg              (default: var(--surface-inverse))
 *   --bds-cta-heading-color   (default: var(--text-inverse))
 *   --bds-cta-body-color      (default: var(--text-secondary-inverse))
 *
 * a11y: h2 + aria-labelledby. Center-aligned but reading order is
 * natural (heading → body → CTA). CTA uses :focus-visible ring with
 * high contrast against the dark background.
 */
import type { BlueprintProps } from './types';

interface Props extends BlueprintProps {}

const { section } = Astro.props;
const titleId = `${section.sectionKey}-title`;
---

<section
  class="bds-cta"
  aria-labelledby={titleId}
  data-blueprint-key="cta_dark_centered"
>
  <div class="bds-cta__container">
    <div class="bds-cta__message">
      <h2 id={titleId} class="bds-cta__title">{section.heading}</h2>
      {section.body && (
        <p class="bds-cta__description">{section.body}</p>
      )}
      {section.cta && 'url' in section.cta && (
        <div class="bds-cta__actions">
          <a href={section.cta.url} class="bds-button bds-button--primary bds-button--lg"><span class="bds-button__content">{section.cta.label}</span></a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .bds-cta {
    background: var(--bds-cta-bg, var(--surface-inverse, var(--color-grayscale-black)));
    padding-block: clamp(var(--space-3xl), 8vw, var(--space-5xl));
  }

  .bds-cta__container {
    max-width: var(--size-container-md, 960px);
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .bds-cta__message {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .bds-cta__title {
    margin: 0;
    font-family: var(--font-family-heading);
    font-size: clamp(var(--heading-xl), 4vw, var(--display-sm));
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--bds-cta-heading-color, var(--text-inverse, var(--color-grayscale-white)));
  }

  .bds-cta__description {
    margin: 0;
    font-family: var(--font-family-body);
    font-size: var(--heading-sm);
    line-height: var(--line-height-relaxed);
    color: var(--bds-cta-body-color, var(--text-secondary-inverse, var(--color-grayscale-lightest)));
    max-width: 55ch;
  }

  .bds-cta__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }
</style>
