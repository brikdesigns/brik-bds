{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "ES2020",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./dist/content-system",
    "rootDir": "./content-system",
    "paths": {},
    "allowImportingTsExtensions": false,
    "skipLibCheck": true
  },
  "include": ["content-system/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.mdx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/*.test.ts",
    "content-system/blueprints/astro/index.ts"
  ]
}
