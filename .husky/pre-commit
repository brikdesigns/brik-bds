# BDS Component Completeness Check
BARREL="components/ui/index.ts"
UI_DIR="components/ui"
MISSING_INDEX=()
MISSING_EXPORT=()

for dir in "$UI_DIR"/*/; do
  name=$(basename "$dir")
  # Skip if not a directory
  [ -d "$dir" ] || continue
  # Check for index.ts
  if [ ! -f "${dir}index.ts" ]; then
    MISSING_INDEX+=("$dir")
  fi
  # Check for barrel export
  if ! grep -q "export \* from './${name}'" "$BARREL" 2>/dev/null; then
    MISSING_EXPORT+=("$name")
  fi
done

if [ ${#MISSING_INDEX[@]} -gt 0 ] || [ ${#MISSING_EXPORT[@]} -gt 0 ]; then
  echo ""
  echo "✗ BDS Component Completeness Check"
  echo ""
  if [ ${#MISSING_INDEX[@]} -gt 0 ]; then
    echo "  Missing index.ts:"
    for item in "${MISSING_INDEX[@]}"; do
      echo "    $item"
    done
  fi
  if [ ${#MISSING_EXPORT[@]} -gt 0 ]; then
    echo "  Missing barrel export in components/ui/index.ts:"
    for item in "${MISSING_EXPORT[@]}"; do
      echo "    $item — add: export * from './${item}';"
    done
  fi
  echo ""
  echo "  Fix these before committing."
  echo ""
  exit 1
fi

# Lint only staged .tsx files (not all components)
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- 'components/**/*.tsx')

if [ -n "$STAGED" ]; then
  echo "Linting $(echo "$STAGED" | wc -l | tr -d ' ') staged .tsx files..."
  node scripts/lint-tokens.js --errors-only --files $STAGED
else
  echo "No staged .tsx files — skipping token lint."
fi

# Typecheck always runs (fast, catches real errors)
npm run typecheck
