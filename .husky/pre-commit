#!/bin/sh

# BDS Component Completeness Check
BARREL="components/ui/index.ts"
UI_DIR="components/ui"
MISSING_INDEX=""
MISSING_EXPORT=""

for dir in "$UI_DIR"/*/; do
  name=$(basename "$dir")
  # Skip if not a directory
  [ -d "$dir" ] || continue
  # Check for index.ts
  if [ ! -f "${dir}index.ts" ]; then
    MISSING_INDEX="$MISSING_INDEX $dir"
  fi
  # Check for barrel export
  if ! grep -q "export \* from './${name}'" "$BARREL" 2>/dev/null; then
    MISSING_EXPORT="$MISSING_EXPORT $name"
  fi
done

if [ -n "$MISSING_INDEX" ] || [ -n "$MISSING_EXPORT" ]; then
  echo ""
  echo "✗ BDS Component Completeness Check"
  echo ""
  if [ -n "$MISSING_INDEX" ]; then
    echo "  Missing index.ts:"
    for item in $MISSING_INDEX; do
      echo "    $item"
    done
  fi
  if [ -n "$MISSING_EXPORT" ]; then
    echo "  Missing barrel export in components/ui/index.ts:"
    for item in $MISSING_EXPORT; do
      echo "    $item — add: export * from './${item}';"
    done
  fi
  echo ""
  echo "  Fix these before committing."
  echo ""
  exit 1
fi

# Lint staged .tsx and .css files for token violations
STAGED_TSX=$(git diff --cached --name-only --diff-filter=ACM -- 'components/**/*.tsx')
STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM -- 'components/**/*.css')

if [ -n "$STAGED_TSX" ] || [ -n "$STAGED_CSS" ]; then
  TSX_COUNT=$([ -n "$STAGED_TSX" ] && echo "$STAGED_TSX" | wc -l | tr -d ' ' || echo "0")
  CSS_COUNT=$([ -n "$STAGED_CSS" ] && echo "$STAGED_CSS" | wc -l | tr -d ' ' || echo "0")
  echo "Linting $TSX_COUNT staged .tsx + $CSS_COUNT staged .css files..."
  node scripts/lint-tokens.js --errors-only \
    ${STAGED_TSX:+--files $STAGED_TSX} \
    ${STAGED_CSS:+--css-files $STAGED_CSS}

  # JSDoc / story-metadata gate. Whole-repo scan (fast) — fires only when a
  # component or story TSX is staged so we don't pay the cost on token-only
  # commits. Enforces @summary on every component + story export and a
  # surface-* tag on every story meta. See scripts/lint-jsdoc.js.
  echo "Running JSDoc lint..."
  node scripts/lint-jsdoc.js
else
  echo "No staged component files — skipping token + JSDoc lint."
fi

# ── Storybook page recipe (ADR-007) ──
# Whole-repo scan; fires only when a component MDX file is staged so
# token-only or test-only commits don't pay the cost.
STAGED_MDX=$(git diff --cached --name-only --diff-filter=ACM -- 'components/ui/**/*.mdx')
if [ -n "$STAGED_MDX" ]; then
  echo "Linting Storybook page recipe (ADR-007)..."
  node scripts/lint-storybook-recipe.js --enforce
fi

# Typecheck always runs (fast, catches real errors)
npm run typecheck

# ── Anti-slop CRITICAL check ──
# Blocks commits that introduce silent bugs on staged files:
#   - empty catch blocks
#   - swallowed promise rejections
#   - relative/@-aliased imports that don't resolve on disk
#
# HIGH findings (raw hex, arbitrary Tailwind values, raw rgba) are surfaced by
# the token lint block above, so this gate only raises threshold to CRITICAL.
#
# Scanner lives at ~/.claude/skills/anti-slop/ (global install). If it's
# missing (fresh machine, CI), the helper gracefully skips — pre-commit
# never breaks for infra reasons.
#
# Build artifacts (dist/) are excluded: Vite bundles third-party deps
# (Radix, React) whose minified output contains legitimate empty-catch
# patterns. Scanning them flags CRITICAL false positives on release commits.
# Release PRs stage only dist/ + package.json, so when every scanner-eligible
# staged file lives under dist/, the scan is skipped. Feature commits still
# scan normally.
ANTI_SLOP_CHECK="$HOME/.claude/skills/anti-slop/brik-rules/check-staged.sh"
if [ -x "$ANTI_SLOP_CHECK" ]; then
  NON_DIST_STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null \
    | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|css|scss|py)$' \
    | grep -v '^dist/' \
    || true)

  if [ -z "$NON_DIST_STAGED" ]; then
    echo "🔍 Anti-slop scan skipped — only build artifacts (dist/) staged."
  else
    echo "🔍 Running anti-slop CRITICAL scan on staged files..."
    if ! "$ANTI_SLOP_CHECK" critical; then
      echo "   Silent-failure + hallucinated-import findings block commits."
      echo "   Fix the listed lines, or justify inline with a logger/throw."
      echo "   To bypass (not recommended): git commit --no-verify"
      exit 1
    fi
  fi
fi
