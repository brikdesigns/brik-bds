{
  "name": "@brikdesigns/bds",
  "version": "0.1.0",
  "description": "Brik Design System - React component library with Webflow-synced design tokens",
  "private": false,
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/lib-entry.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib-entry.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./bridge.css": "./dist/bridge.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@notionhq/client": "^3.1.3",
    "@storybook/addon-a11y": "^8.5.0",
    "@storybook/addon-docs": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/react": "^8.5.0",
    "@storybook/react-vite": "^8.5.0",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.10.0",
    "dotenv": "^16.6.1",
    "fs-extra": "^11.1.1",
    "husky": "^9.1.7",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.5.0",
    "style-dictionary": "^5.3.1",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-svg-core": ">=7.0.0",
    "@fortawesome/free-solid-svg-icons": ">=7.0.0",
    "@fortawesome/react-fontawesome": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "python3 -m http.server 8000",
    "dev": "python3 -m http.server 8000",
    "serve": "python3 -m http.server 8000",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint-tokens": "node scripts/lint-tokens.js",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/lint-tokens.js --errors-only && npm run typecheck && npm run build-storybook",
    "precommit": "npm run validate",
    "extract-tokens": "node scripts/extract-tokens-css.js",
    "build:tokens": "node tokens/build.js",
    "build:dtcg": "node scripts/css-to-dtcg.js",
    "build:sd": "npx style-dictionary build --config sd.config.mjs",
    "build:sd-figma": "node scripts/flatten-tokens-studio.js && npx style-dictionary build --config sd.config.tokens-studio.mjs",
    "build:all-tokens": "npm run build:dtcg && npm run build:sd && npm run build:tokens",
    "build:lib": "vite build --config vite.config.lib.ts && npm run build:types && npm run build:dist-tokens",
    "build:types": "tsc --project tsconfig.build.json",
    "build:dist-tokens": "node scripts/build-dist-tokens.js",
    "deploy": "webflow deploy",
    "deploy:staging": "npm run build-storybook && npx netlify-cli deploy --dir=storybook-static",
    "deploy:prod": "npm run build-storybook && npx netlify-cli deploy --prod --dir=storybook-static",
    "test": "echo \"No tests specified\" && exit 0",
    "test-integration": "node scripts/test-integration.js",
    "setup-copilot": "node scripts/setup-copilot-onlook.js",
    "open-onlook": "echo \"Visit https://onlook.com to connect your repository\"",
    "copilot-guide": "open VISUAL_COPILOT_GUIDE.md",
    "onlook-guide": "open ONLOOK_GUIDE.md",
    "sync:figma": "node scripts/transform-figma-export.js && npm run build:all-tokens",
    "sync:figma:check": "node scripts/transform-figma-export.js --dry-run --compare",
    "populate-notion": "node scripts/populate-notion-tokens.js",
    "propagate": "bash scripts/propagate.sh",
    "propagate:dry": "bash scripts/propagate.sh --dry-run",
    "prepare": "husky"
  },
  "keywords": [
    "webflow",
    "business",
    "template",
    "responsive",
    "brik",
    "design",
    "figma",
    "design-tokens"
  ],
  "author": "Brik Designs",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikdesigns/brik-bds.git"
  },
  "bugs": {
    "url": "https://github.com/brikdesigns/brik-bds/issues"
  },
  "homepage": "https://brik-bds.io/"
}
